meta {
  name: Readiness (Public API)
  type: http
  seq: 2
}

get {
  url: {{api_base}}/health/ready
  body: none
  auth: inherit
}

tests {
  test("status is 200 or 503", function() {
    expect([200, 503]).to.include(res.status);
  });
}

docs {
  Readiness probe. Checks PostgreSQL + Weaviate. Returns `degraded` (still 200) or 503 if a
  backing service is unhealthy.
}
