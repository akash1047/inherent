meta {
  name: Get Ingestion Status
  type: http
  seq: 3
}

get {
  url: {{ingest_base}}/ingest/{{document_id}}/status
  body: none
  auth: inherit
}

tests {
  test("status is 200 or 404 (no running workflow)", function() {
    expect([200, 404]).to.include(res.status);
  });
}

docs {
  Query the real-time progress of an ingestion workflow (`step`, `progress`, `chunks_created`).
  404 if no workflow exists or it is no longer queryable.
}
