meta {
  name: Search with Context Window
  type: http
  seq: 4
}

post {
  url: {{api_base}}/v1/search
  body: json
  auth: inherit
}

headers {
  X-Workspace-Id: {{workspace_id}}
}

body:json {
  {
    "query": "supported file formats",
    "limit": 3,
    "include_context": true,
    "context_window": 2
  }
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });
}

docs {
  Includes surrounding chunks per result (`context_before`/`context_after`).
}
