meta {
  name: Hybrid Search
  type: http
  seq: 2
}

post {
  url: {{api_base}}/v1/search
  body: json
  auth: inherit
}

headers {
  X-Workspace-Id: {{workspace_id}}
}

body:json {
  {
    "query": "document ingestion pipeline",
    "limit": 5,
    "search_mode": "hybrid",
    "alpha": 0.6
  }
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });
}

docs {
  Hybrid search. `alpha` weights vector (1.0) vs keyword (0.0).
}
