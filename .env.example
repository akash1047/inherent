# Copy to .env. Defaults mirror docker-compose.yml + service settings.
# LOCAL-ONLY values are dev placeholders; do not reuse in production.

# --- Postgres (Compose host port 15432) ---
POSTGRES_USER=postgres                  # LOCAL-ONLY
POSTGRES_PASSWORD=postgres              # LOCAL-ONLY
POSTGRES_DB=knowledge_base
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/knowledge_base

# --- MongoDB (Compose host port 27018) ---
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB_NAME=main

# --- Weaviate (Compose host ports 18080 HTTP, 15051 gRPC) ---
WEAVIATE_URL=http://weaviate:8080
# WEAVIATE_API_KEY=
# WEAVIATE_HOST=localhost               # public-api fallback when WEAVIATE_URL unset
# WEAVIATE_PORT=8080

# --- Valkey / Redis (Compose host port 16379) ---
REDIS_URL=redis://valkey:6379
MQ_REDIS_URL=redis://valkey:6379

# --- S3 / s3rver (Compose host port 19000) ---
AWS_ACCESS_KEY_ID=S3RVER                # LOCAL-ONLY
AWS_SECRET_ACCESS_KEY=S3RVER            # LOCAL-ONLY
AWS_REGION=us-east-1
AWS_S3_REGION=us-east-1                 # keep aligned with AWS_REGION
AWS_S3_BUCKET=inherent-documents
AWS_S3_ENDPOINT=http://s3rver:9000

# --- TEI embedding sidecar (Compose host port 18088) ---
EMBEDDING_MODEL_ID=BAAI/bge-small-en-v1.5
EMBEDDING_SERVICE_URL=http://text-embeddings-inference:80
EMBEDDING_DIM=384
EMBEDDING_ENABLED=true

# --- Temporal (Compose host ports 17233 gRPC, 18233 UI) ---
TEMPORAL_ENABLED=true
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=document-ingestion
TEMPORAL_AUDIT_NAMESPACE=audit
TEMPORAL_AUDIT_TASK_QUEUE=audit-writer-queue

# --- inh-ingestion-svc (Compose host ports 18002 API, 19090 metrics) ---
# SERVICE_MODE and API_PORT collide with inh-public-api-svc. In Compose,
# each service receives its own value via the per-service `environment:`
# block. Leave commented here so a copied `.env` does not break host-run
# public-api (its Literal rejects "worker", and public-api's
# `effective_api_port` would pick up API_PORT=8000 over PORT=8080).
# Uncomment only when running ingestion-svc directly on the host without
# public-api in the same process.
# SERVICE_MODE=worker                     # worker | standalone
API_HOST=0.0.0.0
# API_PORT=8000                           # ingestion default; collides with public-api
METRICS_PORT=9090
INGESTION_API_KEY=dev-ingestion-key     # LOCAL-ONLY
STORAGE_BACKEND=s3                      # local | gcs | s3
STORAGE_BUCKET=inherent-documents
# LOCAL_STORAGE_PATH=
# INTG_SERVICE_URL=http://localhost:4000
MQ_BACKEND=redis                        # redis | pubsub | memory
MQ_UPLOAD_TOPIC=core.document.uploaded.v1
MQ_COMPLETION_TOPIC=core.document.processed.v1
MQ_CONSUMER_GROUP=ingestion-workers
CHUNKING_STRATEGY=sentences             # tokens | sentences | paragraphs
MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_WORKERS=4
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5
TENANT_IDLE_DAYS=30
AUTO_CREATE_TENANTS=true
AUDIT_LOG_TOPIC=audit.log.write
AUDIT_CONSUMER_GROUP=ingestion-audit-writers
# GCP_PROJECT_ID=                       # only when STORAGE_BACKEND=gcs or MQ_BACKEND=pubsub
# PUBSUB_SUBSCRIPTION=unused
CONFIG_PATH=config/sources.yaml
LOG_LEVEL=INFO

# --- inh-public-api-svc (Compose host port 18000) ---
# SERVICE_MODE collides with ingestion-svc; Compose sets each service separately.
# SERVICE_MODE=both                     # api | mcp | both
PORT=8080
MCP_PORT=8001
ENVIRONMENT=development                 # development | production
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_DEFAULT=100
# CORS_ORIGINS=["*"]
# CORS_ALLOW_CREDENTIALS=true
ENABLE_HSTS=true
API_KEY_HEADER_NAME=X-API-Key
METRICS_ENABLED=true
METRICS_PATH=/metrics
HEALTH_CHECK_TIMEOUT_SECONDS=5.0
AUDIT_LOG_ENABLED=true

# --- Cloud SQL (production only) ---
# USE_CLOUD_SQL_CONNECTOR=false
# CLOUD_SQL_INSTANCE=project:region:instance
# CLOUD_SQL_DATABASE=knowledge_base
# CLOUD_SQL_USER=ingestion_user
# CLOUD_SQL_PASSWORD=
# CLOUD_SQL_USE_IAM_AUTH=true
